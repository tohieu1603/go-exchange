# Micro-Exchange — environment template
# Copy to `.env` (git-ignored) and edit. Each Go service auto-loads `.env`.

# ── Secrets ────────────────────────────────────────────────────────────────
# 32+ random bytes, base64. Used to sign access + refresh JWTs across services.
JWT_SECRET=change-me-to-a-32-byte-random-secret

# ── Step-up authentication ────────────────────────────────────────────────
# When `true`, login from a new device fingerprint requires email OTP
# verification. Off by default in dev so the email transport is not required.
STEP_UP_ENABLED=false

# ── Cookie envelope (BE → browser) ────────────────────────────────────────
# Production must set both:
#   COOKIE_SECURE=true      → cookie only sent over HTTPS
#   COOKIE_SAMESITE=none    → SPA on a different registrable domain than API
#                             (e.g. app.example.com + api.example.com)
# When SPA + API share the same registrable domain, leave both at defaults.
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# ── CORS allow list ────────────────────────────────────────────────────────
# Comma-separated origins that may make credentialed requests. Each must be a
# full origin (scheme + host + optional port). Wildcards are NOT honoured by
# browsers when Allow-Credentials=true.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Service URLs (gateway → services) ─────────────────────────────────────
AUTH_URL=http://localhost:8081
WALLET_URL=http://localhost:8082
MARKET_URL=http://localhost:8083
TRADING_URL=http://localhost:8084
FUTURES_URL=http://localhost:8085
NOTIFICATION_URL=http://localhost:8086
AUTH_GRPC_ADDR=localhost:9081
WALLET_GRPC_ADDR=localhost:9082
MARKET_GRPC_ADDR=localhost:9083

# ── Infrastructure ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6389
KAFKA_BROKERS=localhost:9192
ELASTIC_URL=http://localhost:9201
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# ── Per-service Postgres DSNs (override only if non-default) ──────────────
# Each service auto-builds DSN from POSTGRES_HOST/USER/PASSWORD/DB if unset.
# AUTH_DSN=postgres://postgres:postgres@localhost:5551/auth_db?sslmode=disable
# WALLET_DSN=...

# ── HTTP ports ─────────────────────────────────────────────────────────────
# Override only when port collides with a host service.
# GATEWAY_PORT=8080
# AUTH_HTTP_PORT=8081
